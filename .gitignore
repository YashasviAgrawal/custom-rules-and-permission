# ============================================================
# Django / DRF Project .gitignore
# ============================================================

# ----------------------------------------------------------
# Environment & Secrets
# ----------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
secrets.json

# ----------------------------------------------------------
# Python
# ----------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
wheels/
*.whl
MANIFEST

# ----------------------------------------------------------
# Virtual Environments
# ----------------------------------------------------------
env/
venv/
.venv/
ENV/
env.bak/
venv.bak/

# ----------------------------------------------------------
# Django
# ----------------------------------------------------------
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
/static/
/staticfiles/
/mediafiles/
/media/

# ----------------------------------------------------------
# Database dumps / backups
# ----------------------------------------------------------
*.sql
*.dump
customdatabse

# ----------------------------------------------------------
# Docker
# ----------------------------------------------------------
.docker/

# ----------------------------------------------------------
# Testing & Coverage
# ----------------------------------------------------------
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
htmlcov/
.pytest_cache/
pytestdebug.log

# ----------------------------------------------------------
# IDEs & Editors
# ----------------------------------------------------------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ----------------------------------------------------------
# Miscellaneous
# ----------------------------------------------------------
*.bak
*.tmp
*.temp
